// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model user {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  clerkId   String   @unique
  firstName String
  lastName  String
  email     String   @unique
  role      ROLE     @default(USER)
  imgUrl    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ROLE {
  ADMIN
  USER
}

model Vehicle {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  modelName     String
  category      VehicleCategory @default(PREMIUM)
  maxPassengers Int
  pricePerKm    Float
  minBudget     Float
  features      String
  image         String?
  isAdventure   Boolean         @default(false)
  isAvailable   Boolean         @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  Booking   Booking[]
}

enum VehicleCategory {
  BUDGET
  PREMIUM
  XL_LUXURY
  VANS
}

model Booking {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String
  userEmail  String
  vehicleId  String   @db.ObjectId
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id])
  amount     Float
  guestCount Int
  from       String
  startDate  String
  endDate    String
  to         String
  distance   Float? // Add '?' to make it optional
  paymentId  String?  @unique // Add '?' because it's null until payment is done
  orderId    String   @unique
  status     String   @default("PENDING") // Start as PENDING
  createdAt  DateTime @default(now())
}
