{
	"name": "azadtours",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"prisma_generate_dev": "dotenv -e .env -- prisma generate",
		"prisma_generate_prod": "dotenv -e .env.prod -- prisma generate",
		"prisma_db_push_dev": "dotenv -e .env -- prisma db push",
		"prisma_db_push_prod": "dotenv -e .env.prod -- prisma db push",
		"prisma_db_pull_dev": "dotenv -e .env -- prisma db pull",
		"prisma_db_pull_prod": "dotenv -e .env.prod -- prisma db pull",
		"prisma_sync_dev": "npm run prisma_db_push_dev && npm run prisma_generate_dev",
		"prisma_sync_prod": "npm run prisma_db_push_prod && npm run prisma_generate_prod",
		"prisma_studio_dev": "dotenv -e .env -- prisma studio",
		"prisma_studio_prod": "dotenv -e .env.prod -- prisma studio",
		"prisma_format": "prisma format",
		"prisma_validate": "prisma validate",
		"dev": "next dev",
		"build": "prisma generate && next build",
		"start": "next start",
		"lint": "eslint"
	},
	"dependencies": {
		"@clerk/elements": "^0.24.13",
